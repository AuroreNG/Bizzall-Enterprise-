.dash-logo{font-weight:950;color:var(--navy)}
.metrics{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
.metric{background:white;border:1px solid #e4edf8;border-radius:14px;padding:16px}
.metric b{display:block;font-size:24px;color:#071430}
.metric small{color:var(--green);font-weight:900}
.chart{height:150px;margin-top:16px;border-radius:16px;background:linear-gradient(135deg,#eef5ff,#fff);display:grid;place-items:center;color:var(--blue);font-weight:900}
section{width:min(1180px,92%);margin:0 auto 80px}
.section-head{text-align:center;max-width:780px;margin:0 auto 38px}
.section-head h2{font-size:clamp(32px,4vw,48px);line-height:1.08;margin:0 0 12px;color:var(--navy);letter-spacing:-.05em}
.section-head p{color:#64748B;font-size:17px;font-weight:600;line-height:1.6}
.cards{display:grid;grid-template-columns:repeat(3,1fr);gap:22px}
.card{background:white;border:1px solid #e4edf8;border-radius:24px;padding:28px;box-shadow:0 16px 44px rgba(15,23,42,.07);transition:.25s}
.card:hover{transform:translateY(-5px);box-shadow:0 24px 60px rgba(6,26,58,.13)}
.icon{width:58px;height:58px;border-radius:16px;display:grid;place-items:center;background:linear-gradient(135deg,var(--blue),var(--royal));color:white;font-size:28px;margin-bottom:18px}
.card h3{font-size:24px;margin:0 0 8px;color:var(--navy)}
.card p{color:#64748B;line-height:1.6;font-weight:600}
.card ul{list-style:none;padding:0;margin:18px 0;display:grid;gap:10px}
.card li{font-weight:700;color:#334155}
.card li:before{content:"✓";color:var(--green);font-weight:950;margin-right:8px}
.features{display:grid;grid-template-columns:repeat(6,1fr);gap:16px}
.feature{text-align:center;background:white;border:1px solid #e4edf8;border-radius:20px;padding:22px 14px}
.feature div{font-size:28px;color:var(--blue)}
.feature h4{margin:10px 0 6px;color:var(--navy)}
.feature p{font-size:13px;color:#64748B;line-height:1.5;margin:0;font-weight:600}
.cta{background:linear-gradient(135deg,var(--navy),var(--blue));color:white;border-radius:30px;padding:45px;display:grid;grid-template-columns:1.2fr .8fr;gap:24px;align-items:center;box-shadow:var(--shadow)}
.cta h2{font-size:38px;margin:0 0 12px}
.cta p{color:#dbeafe;font-size:17px;line-height:1.6}
.cta-actions{display:flex;gap:14px;justify-content:flex-end;flex-wrap:wrap}
footer{width:min(1180px,92%);margin:auto;padding:34px 0;border-top:1px solid #dce8f8;display:flex;align-items:center;justify-content:space-between;gap:20px;color:#64748B;font-weight:600}
footer img{width:155px}
.hamburger{display:none;background:none;border:0;font-size:30px;color:var(--navy)}
.mobile{display:none}
@media(max-width:900px){
.hero,.cta{grid-template-columns:1fr}
.cards{grid-template-columns:1fr}
.features{grid-template-columns:repeat(2,1fr)}
.nav-links{display:none}
.hamburger{display:block}
.mobile.active{display:flex;position:fixed;inset:0;background:rgba(6,26,58,.97);z-index:99;flex-direction:column;align-items:center;justify-content:center;gap:28px}
.mobile a{color:white;font-size:22px;font-weight:900}
.cta-actions{justify-content:flex-start}
footer{flex-direction:column;text-align:center}
}
</style>

