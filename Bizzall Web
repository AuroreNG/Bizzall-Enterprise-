
<style>
:root{--blue:#004AAD;--royal:#0B5CFF;--navy:#061A3A;--text:#111827;--muted:#64748B;--light:#F5F8FF;--white:#fff;--green:#00A86B;--shadow:0 24px 60px rgba(6,26,58,.14)}
*{box-sizing:border-box}
html{scroll-behavior:smooth}
body{margin:0;font-family:Inter,Arial,sans-serif;color:var(--text);background:linear-gradient(120deg,#fff 0%,#fff 45%,#edf5ff 100%)}
a{text-decoration:none;color:inherit}
.page{overflow:hidden}
.nav{width:min(1180px,92%);margin:auto;padding:16px 0;display:flex;align-items:center;justify-content:space-between}
